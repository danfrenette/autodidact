#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
WEB_PORT="${WEB_PORT:-3000}"
TAILNET_HOST="$(tailscale status --self --json | ruby -rjson -e 'puts JSON.parse(STDIN.read).fetch("Self").fetch("DNSName").sub(/\.$/, "")')"

export BETTER_AUTH_URL="https://$TAILNET_HOST:$WEB_PORT"
export BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:$WEB_PORT,http://127.0.0.1:$WEB_PORT,https://$TAILNET_HOST:$WEB_PORT"

cleanup() {
  if [[ -n "${TAILNET_SERVE_PID:-}" ]]; then
    kill "$TAILNET_SERVE_PID" 2>/dev/null || true
  fi
}

trap cleanup EXIT INT TERM

"$ROOT_DIR/bin/tailnet-serve" &
TAILNET_SERVE_PID="$!"

"$ROOT_DIR/bin/dev" "$@"
