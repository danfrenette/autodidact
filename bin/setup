#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"

echo "==> Installing Rails dependencies"
bundle install --gemfile "$ROOT_DIR/api/Gemfile"

echo "==> Preparing Rails database"
(cd "$ROOT_DIR/api" && bin/rails db:prepare)

echo "==> Installing frontend dependencies"
(cd "$ROOT_DIR/web" && pnpm install)

echo "==> Setup complete"
