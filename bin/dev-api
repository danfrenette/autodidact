#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"

cd "$ROOT_DIR"
export BUNDLE_GEMFILE="$ROOT_DIR/api/Gemfile"

"$ROOT_DIR/bin/auth-migrate"

set -a
# shellcheck disable=SC1091
. "$ROOT_DIR/web/.env.local"
set +a

cd "$ROOT_DIR/api"
exec bundle exec rails server -p "${PORT:-3001}"
