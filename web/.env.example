# Rails API base URL used by the TanStack Start tRPC layer.
RAILS_API_URL=http://localhost:3001

# Optional Rails healthcheck path. The Rails default is usually /up.
RAILS_HEALTHCHECK_PATH=/up

# Database URL for Better Auth (shared with Rails).
DATABASE_URL=postgres://localhost:5432/autodidact_development

# Better Auth configuration.
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-to-a-long-random-string

# GitHub OAuth credentials (required for GitHub sign-in).
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth credentials (required for Google sign-in).
# Create at: https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sentry configuration.
VITE_SENTRY_DSN=
VITE_SENTRY_ORG=
VITE_SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
