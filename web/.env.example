# Rails API base URL used by the TanStack Start tRPC layer.
RAILS_API_URL=http://localhost:3001

# Optional Rails healthcheck path. The Rails default is usually /up.
RAILS_HEALTHCHECK_PATH=/up

# Better Auth configuration.
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-to-a-long-random-string

# Sentry configuration.
VITE_SENTRY_DSN=
VITE_SENTRY_ORG=
VITE_SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
